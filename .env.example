# PostgreSQL read-only connection (psycopg3 URL)
MCP_DATABASE_URL=postgresql+psycopg://readonly_user:password@host:5432/dbname

# GitHub OAuth app credentials (create at github.com/settings/apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public base URL for OAuth discovery and redirect endpoints
MCP_BASE_URL=https://mcp.etfedge.xyz

# Optional overrides
# MCP_HOST=127.0.0.1
# MCP_PORT=8000
